# ============================================================
# Data — NOT redistributable (paid WRDS / S&P Capital IQ data)
# ============================================================
# Raw CIQ Transcripts (2.8 GB). Redistribution violates the WRDS
# license agreement. Regenerate locally via transcripts.py.
transcripts_data/

# All derivative datasets built from WRDS CIQ / CRSP / IBES / Compustat.
# These are derivative works of paid data and are license-restricted.
# Regenerate locally by running the pipeline (see README.md).
*.parquet

# Full LLM output (162,677 responses) — derivative of WRDS data.
# Only sample_production_output.jsonl (first 100 lines) is tracked.
production_deepseek.jsonl
pilot_deepseek.jsonl
*.jsonl
!data/sample_production_output.jsonl
!sample_production_output.jsonl

